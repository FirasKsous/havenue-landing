# =============================================================================
# CateringOS Landing Page — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# -----------------------------------------------------------------------------
# Supabase (Frontend — public keys only)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# -----------------------------------------------------------------------------
# Stripe (Frontend — publishable key only)
# -----------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# Stripe Price IDs (Frontend — used in PricingSection for checkout routing)
# -----------------------------------------------------------------------------
VITE_STRIPE_PRICE_STARTER_MONTHLY=price_...
VITE_STRIPE_PRICE_STARTER_ANNUAL=price_...
VITE_STRIPE_PRICE_PRO_MONTHLY=price_...
VITE_STRIPE_PRICE_PRO_ANNUAL=price_...

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
VITE_GA4_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Demo Video (YouTube/Vimeo embed URL — leave empty for "Coming Soon" state)
# -----------------------------------------------------------------------------
VITE_DEMO_VIDEO_URL=

# -----------------------------------------------------------------------------
# Calendly (Enterprise "Talk to Sales" scheduling)
# -----------------------------------------------------------------------------
VITE_CALENDLY_URL=https://calendly.com/your-team/enterprise-demo

# =============================================================================
# EDGE FUNCTION SECRETS (set via Supabase Dashboard or CLI, NOT in this file)
# =============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# RESEND_API_KEY=re_...
# RESEND_FROM_TRANSACTIONAL=Product Notifications <notifications@example.com>
# LOOPS_API_KEY=...
# PUBLIC_SITE_ORIGIN=https://your-havenue-domain.com
# CORS_ALLOWED_ORIGINS=https://your-havenue-domain.com,http://localhost:5173,http://127.0.0.1:5173
# MAKE_WEBHOOK_CALENDLY=https://hook.eu2.make.com/...
# MAKE_WEBHOOK_HIGH_SCORE_LEAD=https://hook.eu2.make.com/...
# MAKE_WEBHOOK_DISPUTE_ALERT=https://hook.eu2.make.com/...
# SLACK_WEBHOOK_SALES=https://hooks.slack.com/services/...
# SLACK_WEBHOOK_OPS=https://hooks.slack.com/services/...
