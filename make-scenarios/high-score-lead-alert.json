{
  "name": "Havenue — High-Score Lead → Slack Alert",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": 0,
        "maxResults": 1,
        "name": "Havenue High-Score Lead Webhook"
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "expect": [
          { "name": "type", "type": "text", "required": true },
          { "name": "email", "type": "text", "required": true },
          { "name": "score", "type": "number" },
          { "name": "source", "type": "text" },
          { "name": "company", "type": "text" }
        ]
      }
    },
    {
      "id": 2,
      "module": "slack:ActionPostMessage",
      "version": 1,
      "parameters": { "connection": 0 },
      "mapper": {
        "channel": "#sales-alerts",
        "text": "🔥 *High-Score Lead Alert*\n\n*Email:* {{1.email}}\n*Score:* {{1.score}}/100\n*Source:* {{1.source}}\n*Type:* {{1.type}}\n\n_Lead score ≥ 71 — Sales Qualified. Follow up within 1 hour._"
      },
      "metadata": { "designer": { "x": 300, "y": 0 } }
    }
  ]
}
